  profile_id String          @db.Uuid
  role       String?
  joined_at  DateTime        @default(now()) @db.Timestamptz(6)
  left_at    DateTime?       @db.Timestamptz(6)
  team       MaintenanceTeam @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles   profiles        @relation(fields: [profile_id], references: [id], onUpdate: NoAction)

  @@unique([team_id, profile_id], map: "uq_maintenance_team_members")
  @@map("maintenance_team_members")
  @@index([team_id], map: "idx_maintenance_team_members_team")
  @@index([profile_id], map: "idx_maintenance_team_members_profile")
}

model PurchaseOrder {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  po_number           String             @unique
  purchase_request_id String?            @db.Uuid
  work_order_id       String?            @db.Uuid
  supplier            String?
  status              String             @default("Draft")
  total_amount        Decimal            @default(0) @db.Decimal(12, 3)
  currency            String             @default("KWD")
  approved_by         String?            @db.Uuid
  approved_at         DateTime?          @db.Timestamptz(6)
  ordered_at          DateTime?          @db.Timestamptz(6)
  received_at         DateTime?          @db.Timestamptz(6)
  notes               String?
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime           @default(now()) @db.Timestamptz(6)
  created_by          String?            @db.Uuid
  purchase_requests   purchase_requests? @relation(fields: [purchase_request_id], references: [id], onUpdate: NoAction)
  items               PurchaseOrderItem[]

  @@map("purchase_orders")
  @@index([purchase_request_id], map: "idx_purchase_orders_pr")
  @@index([status], map: "idx_purchase_orders_status")
  @@index([created_at], map: "idx_purchase_orders_created_at")
}

model PurchaseOrderItem {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchase_order_id String        @db.Uuid
  part_id           String?       @db.Uuid
  description       String
  quantity          Decimal       @default(0) @db.Decimal(12, 2)
  unit_price        Decimal       @default(0) @db.Decimal(12, 3)
  total_price       Decimal       @default(0) @db.Decimal(12, 3)
  received_qty      Decimal       @default(0) @db.Decimal(12, 2)
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  purchase_order    PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parts             parts?        @relation(fields: [part_id], references: [id], onUpdate: NoAction)

  @@map("purchase_order_items")
  @@index([purchase_order_id], map: "idx_purchase_order_items_po")
  @@index([part_id], map: "idx_purchase_order_items_part")
}
