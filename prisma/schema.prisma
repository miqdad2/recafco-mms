  finance_approval_enabled           Boolean  @default(true)
  ceo_approval_enabled               Boolean  @default(true)
  logo_path                          String?
  updated_at                         DateTime @default(now()) @db.Timestamptz(6)
  updated_by                         String?  @db.Uuid
  asset_number_format                String   @default("REC/ASSET/{0000}")
  notification_retention_days        Int      @default(180)
  notification_poll_interval_seconds Int      @default(45)
  force_critical_notifications       Boolean  @default(true)
